# ─────────────────────────────────────────────────────────────
# Q1: 특정 환경요인이 활성화하는 면역 경로 조회
# "PM2.5가 어떤 신호전달 경로를 활성화하는가?"
# ─────────────────────────────────────────────────────────────
# SELECT ?envFactor ?pathway ?cytokine ?correlation ?lagTime
# WHERE {
#     ?envFactor a ico:EnvironmentalFactor ;
#                rdfs:label "PM2.5"@en .
#     ?causalPath a ico:CausalPathway ;
#                 ico:hasCorrelationCoefficient ?correlation ;
#                 ico:hasLagTime ?lagTime .
#     # Traverse: envFactor → pathway → cytokine
# }

# ─────────────────────────────────────────────────────────────
# Q2: 특정 RONS 조합이 제어하는 면역 반응 경로 조회
# "NO + OH 조합은 어떤 경로로 면역을 조절하는가?"
# (인과추론 도구 Ver 1.0 핵심 쿼리)
# ─────────────────────────────────────────────────────────────
# SELECT ?rons ?pathway ?effect ?disease
# WHERE {
#     ?rons a ico:ReactiveSpecies ;
#           rdfs:label ?ronsLabel .
#     FILTER (?ronsLabel IN ("Nitric Oxide", "Hydroxyl Radical"))
#     ?rons ico:activatesPathway ?pathway .
#     ?pathway ico:modulatesImmune ?effect .
#     ?effect ico:treatedBy ?treatment .
# }

# ─────────────────────────────────────────────────────────────
# Q3: 질병 궤적 단계 순서 조회
